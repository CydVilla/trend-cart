generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Safety classification for a post. PENDING = not yet evaluated.
enum SafetyStatus {
  PENDING
  SAFE
  UNSAFE
  UNCERTAIN
}

/// Lifecycle of a bot reply. PENDING_APPROVAL/APPROVED support the
/// manual-approval flow; POSTING is the exactly-once claim state.
enum ReplyStatus {
  DRY_RUN
  PENDING_APPROVAL
  APPROVED
  POSTING
  POSTED
  SKIPPED
  FAILED
}

/// How a post entered the pipeline.
enum PostSource {
  /// Legacy Jetstream-firehose captures (discovery v1, retired)
  FIREHOSE
  /// Bluesky search: top posts of the last 24h per category query
  SEARCH
  MANUAL
  /// Someone tagged the bot asking for a recommendation (solicited)
  MENTION
}

/// A candidate Bluesky post captured from the Jetstream firehose.
model Post {
  id           String   @id @default(cuid())
  /// AT URI, e.g. at://did:plc:abc123/app.bsky.feed.post/3kxyz — globally unique
  uri          String   @unique
  /// Content hash of the record; needed (with uri) to construct a reply ref
  cid          String
  authorDid    String
  /// Handle may be unknown at ingest time (Jetstream sends DIDs); resolved later
  authorHandle String?
  text         String
  /// When the post was indexed by the network (from the event)
  indexedAt    DateTime

  // Engagement counts are 0 at ingest (Jetstream commit events carry no counts);
  // rehydrated later via app.bsky.feed.getPosts using the URI.
  likeCount   Int @default(0)
  repostCount Int @default(0)
  replyCount  Int @default(0)
  quoteCount  Int @default(0)

  /// likeCount*1 + repostCount*3 + replyCount*2 + quoteCount*3
  engagementScore    Float @default(0)
  /// Last time counts were refreshed from the AppView (null = never)
  lastHydratedAt     DateTime?

  /// Category slugs matched by the cheap keyword pre-filter
  detectedCategories String[]     @default([])
  /// The exact keyword phrases that fired (observability + tuning signal)
  matchedKeywords    String[]     @default([])
  /// 0–100, set by LLM evaluation (null = not yet evaluated)
  productIntentScore Int?
  safetyStatus       SafetyStatus @default(PENDING)
  source             PostSource   @default(FIREHOSE)
  /// Set when the post vanished from the AppView (deleted) — never act on it
  deadAt             DateTime?
  /// For MENTION requests made under someone else's post: the parent post's
  /// text, given to the classifier as conversation context
  contextText        String?
  /// Real thread root for MENTION requests (the bot's reply must thread into
  /// the existing conversation, not start a new one). Null → root = the post.
  threadRootUri      String?
  threadRootCid      String?
  /// Operator override: trusted context for the LLM ("the picture shows the
  /// physical edition — recommend that game")
  operatorNote       String?
  /// Operator override: exact Amazon link the reply must use (tag applied at
  /// injection). When set, LLM classification is bypassed entirely.
  operatorLinkUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  evaluations CandidateEvaluation[]
  replies     BotReply[]

  @@index([authorDid])
  @@index([createdAt])
  @@index([engagementScore])
  @@index([safetyStatus, productIntentScore])
}

/// Discovery control: each category's keywords run as Bluesky search queries,
/// and the slug/description guide the LLM's category picks.
model ProductCategory {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  description      String
  /// Bluesky search queries polled each discovery cycle (first 6 used)
  keywords         String[] @default([])
  /// If any of these appear, the category does NOT match
  negativeKeywords String[] @default([])
  /// Example problem statements, used as few-shot context for the LLM
  exampleProblems  String[] @default([])
  isActive         Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Every reply the bot generated — including dry runs and skips —
/// so we can rate-limit, dedupe, and audit.
model BotReply {
  id         String      @id @default(cuid())
  postId     String
  replyText  String
  /// AT URI of the posted reply (null unless status = POSTED)
  replyUri   String?
  status     ReplyStatus
  skipReason String?
  /// The reply's single link, posted as a rich-text facet: replyText shows
  /// linkAnchor as clickable text, linkUrl is the destination. Legacy rows
  /// (null linkUrl) carry a raw URL inside replyText instead.
  linkUrl    String?
  linkAnchor String?
  /// When the reply actually went out — rate limits derive from this
  postedAt   DateTime?
  approvedAt DateTime?
  /// Posting retry bookkeeping (transient errors retry, they don't kill)
  attemptCount  Int       @default(0)
  nextAttemptAt DateTime?
  /// Learning signals: engagement on OUR posted reply, and whether the
  /// operator hand-edited the text before approving
  replyLikeCount    Int       @default(0)
  replyReplyCount   Int       @default(0)
  outcomeCheckedAt  DateTime?
  editedByOperator  Boolean   @default(false)
  /// Original text before the operator's first edit — before/after pairs are
  /// the strongest style signal the reflection job learns from
  preEditText       String?

  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([status, createdAt])
  @@index([createdAt])
}

/// Full record of one evaluation run for a post (inputs, raw LLM output,
/// and the decision) — the audit log for "why did/didn't the bot reply?".
model CandidateEvaluation {
  id                  String       @id @default(cuid())
  postId              String
  /// What we sent to the evaluator (post text, matched categories, etc.)
  rawInput            Json
  /// Raw LLM response, null if the cheap filters rejected before the LLM ran
  llmOutput           Json?
  productIntentScore  Int
  safetyDecision      SafetyStatus
  recommendedCategory String?
  /// Direct Amazon search query for dynamic recommendations (e.g. a game title)
  recommendedSearchQuery String?
  /// 0–100: LLM's confidence that an Amazon search for the query lands on the
  /// product or same-franchise items. Low-confidence queries never get linked.
  /// Pre-existing rows default to 100 (they predate the gate).
  linkConfidence         Int     @default(100)
  /// LLM's suggestion when real intent exists but no category fits
  suggestedNewCategory   String?
  /// Which model produced this verdict ("fake", "policy", or a real model id) —
  /// the reply pipeline only acts on verdicts matching its current mode
  model               String  @default("unknown")
  shouldReply         Boolean
  reason              String
  suggestedReplyAngle String?

  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([createdAt])
}

/// Authors the bot must never reply to again. Populated automatically when
/// anyone interacts with the bot (conservative consent-revocation) or manually.
model AuthorOptOut {
  did       String   @id
  reason    String
  createdAt DateTime @default(now())
}

/// Singleton (id = "worker") liveness + ground-truth mode row, upserted by the
/// worker every 30s. `paused` is the operator kill switch (set by dashboard,
/// read by the worker each tick — the worker never writes it).
model WorkerHeartbeat {
  id           String   @id
  startedAt    DateTime
  updatedAt    DateTime @updatedAt
  dryRun       Boolean
  replyMode    String
  model        String
  paused       Boolean  @default(false)
  /// Operator toggle: bot self-approves high-confidence replies (marginal
  /// ones still queue for manual approval). DRY_RUN overrides this.
  autonomous   Boolean  @default(false)
  postingState String
  loops        Json
  counters     Json
}

/// Small persistent memory the bot writes for itself — currently a single
/// "lessons" row: guidelines distilled daily from operator decisions and
/// posted-reply outcomes, injected into the classifier and reply prompts.
model BotMemory {
  id        String   @id
  content   String
  /// What evidence produced this digest (for auditing the learning loop)
  basis     Json?
  updatedAt DateTime @updatedAt
}
