generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Safety classification for a post. PENDING = not yet evaluated.
enum SafetyStatus {
  PENDING
  SAFE
  UNSAFE
  UNCERTAIN
}

/// Lifecycle of a bot reply. PENDING_APPROVAL/APPROVED support the
/// manual-approval flow; POSTING is the exactly-once claim state.
enum ReplyStatus {
  DRY_RUN
  PENDING_APPROVAL
  APPROVED
  POSTING
  POSTED
  SKIPPED
  FAILED
}

/// How a post entered the pipeline.
enum PostSource {
  /// Legacy Jetstream-firehose captures (discovery v1, retired)
  FIREHOSE
  /// Bluesky search: top posts of the last 24h per category query
  SEARCH
  MANUAL
  /// Someone tagged the bot asking for a recommendation (solicited)
  MENTION
}

/// A candidate Bluesky post captured from the Jetstream firehose.
model Post {
  id           String   @id @default(cuid())
  /// AT URI, e.g. at://did:plc:abc123/app.bsky.feed.post/3kxyz — globally unique
  uri          String   @unique
  /// Content hash of the record; needed (with uri) to construct a reply ref
  cid          String
  authorDid    String
  /// Handle may be unknown at ingest time (Jetstream sends DIDs); resolved later
  authorHandle String?
  text         String
  /// When the post was indexed by the network (from the event)
  indexedAt    DateTime

  // Engagement counts are 0 at ingest (Jetstream commit events carry no counts);
  // rehydrated later via app.bsky.feed.getPosts using the URI.
  likeCount   Int @default(0)
  repostCount Int @default(0)
  replyCount  Int @default(0)
  quoteCount  Int @default(0)

  /// likeCount*1 + repostCount*3 + replyCount*2 + quoteCount*3
  engagementScore    Float @default(0)
  /// Last time counts were refreshed from the AppView (null = never)
  lastHydratedAt     DateTime?

  /// Category slugs matched by the cheap keyword pre-filter
  detectedCategories String[]     @default([])
  /// The exact keyword phrases that fired (observability + tuning signal)
  matchedKeywords    String[]     @default([])
  /// 0–100, set by LLM evaluation (null = not yet evaluated)
  productIntentScore Int?
  safetyStatus       SafetyStatus @default(PENDING)
  source             PostSource   @default(FIREHOSE)
  /// Set when the post vanished from the AppView (deleted) — never act on it
  deadAt             DateTime?
  /// For MENTION requests made under someone else's post: the parent post's
  /// text, given to the classifier as conversation context
  contextText        String?
  /// Real thread root for MENTION requests (the bot's reply must thread into
  /// the existing conversation, not start a new one). Null → root = the post.
  threadRootUri      String?
  threadRootCid      String?
  /// Operator override: trusted context for the LLM ("the picture shows the
  /// physical edition — recommend that game")
  operatorNote       String?
  /// Operator override: exact Amazon link the reply must use (tag applied at
  /// injection). When set, LLM classification is bypassed entirely.
  operatorLinkUrl    String?

  /// Thumbnail URLs of images attached to the post (Bluesky embed), captured
  /// at ingest. Fed to the classifier as vision input so it can SEE what was
  /// shared (a game screenshot, a physical edition) instead of guessing.
  imageUrls          String[] @default([])
  /// Alt text the author wrote for those images — free, descriptive context
  /// (often names the product), passed to the classifier and reply as text.
  imageAlts          String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  evaluations CandidateEvaluation[]
  replies     BotReply[]

  @@index([authorDid])
  @@index([createdAt])
  @@index([engagementScore])
  @@index([safetyStatus, productIntentScore])
}

/// Discovery control: each category's keywords run as Bluesky search queries,
/// and the slug/description guide the LLM's category picks.
model ProductCategory {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  description      String
  /// Bluesky search queries polled each discovery cycle (first 6 used)
  keywords         String[] @default([])
  /// If any of these appear, the category does NOT match
  negativeKeywords String[] @default([])
  /// Example problem statements, used as few-shot context for the LLM
  exampleProblems  String[] @default([])
  isActive         Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Every reply the bot generated — including dry runs and skips —
/// so we can rate-limit, dedupe, and audit.
model BotReply {
  id         String      @id @default(cuid())
  postId     String
  replyText  String
  /// AT URI of the posted reply (null unless status = POSTED)
  replyUri   String?
  status     ReplyStatus
  skipReason String?
  /// The reply's single link, posted as a rich-text facet: replyText shows
  /// linkAnchor as clickable text, linkUrl is the destination. Legacy rows
  /// (null linkUrl) carry a raw URL inside replyText instead.
  linkUrl    String?
  linkAnchor String?
  /// When the reply actually went out — rate limits derive from this
  postedAt   DateTime?
  approvedAt DateTime?
  /// Posting retry bookkeeping (transient errors retry, they don't kill)
  attemptCount  Int       @default(0)
  nextAttemptAt DateTime?
  /// Learning signals: engagement on OUR posted reply, and whether the
  /// operator hand-edited the text before approving
  replyLikeCount    Int       @default(0)
  replyReplyCount   Int       @default(0)
  outcomeCheckedAt  DateTime?
  editedByOperator  Boolean   @default(false)
  /// Original text before the operator's first edit — before/after pairs are
  /// the strongest style signal the reflection job learns from
  preEditText       String?
  /// Post-hoc operator verdict on a POSTED reply ("up" | "down") — the main
  /// feedback channel for autonomously posted replies
  operatorRating    String?
  /// Optional free-text note explaining the rating (fed to reflection/insights)
  operatorFeedback  String?
  ratedAt           DateTime?

  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([status, createdAt])
  @@index([createdAt])
}

/// Full record of one evaluation run for a post (inputs, raw LLM output,
/// and the decision) — the audit log for "why did/didn't the bot reply?".
model CandidateEvaluation {
  id                  String       @id @default(cuid())
  postId              String
  /// What we sent to the evaluator (post text, matched categories, etc.)
  rawInput            Json
  /// Raw LLM response, null if the cheap filters rejected before the LLM ran
  llmOutput           Json?
  productIntentScore  Int
  safetyDecision      SafetyStatus
  recommendedCategory String?
  /// Direct Amazon search query for dynamic recommendations (e.g. a game title)
  recommendedSearchQuery String?
  /// 0–100: LLM's confidence that an Amazon search for the query lands on the
  /// product or same-franchise items. Low-confidence queries never get linked.
  /// Pre-existing rows default to 100 (they predate the gate).
  linkConfidence         Int     @default(100)
  /// LLM's suggestion when real intent exists but no category fits
  suggestedNewCategory   String?
  /// Which model produced this verdict ("fake", "policy", or a real model id) —
  /// the reply pipeline only acts on verdicts matching its current mode
  model               String  @default("unknown")
  shouldReply         Boolean
  reason              String
  suggestedReplyAngle String?

  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([createdAt])
}

/// Authors the bot must never reply to again. Populated automatically when
/// anyone interacts with the bot (conservative consent-revocation) or manually.
model AuthorOptOut {
  did       String   @id
  reason    String
  createdAt DateTime @default(now())
}

/// Singleton (id = "worker") liveness + ground-truth mode row, upserted by the
/// worker every 30s. `paused` is the operator kill switch (set by dashboard,
/// read by the worker each tick — the worker never writes it).
model WorkerHeartbeat {
  id           String   @id
  startedAt    DateTime
  updatedAt    DateTime @updatedAt
  dryRun       Boolean
  replyMode    String
  model        String
  paused       Boolean  @default(false)
  /// Operator toggle: bot self-approves high-confidence replies (marginal
  /// ones still queue for manual approval). DRY_RUN overrides this.
  autonomous   Boolean  @default(false)
  postingState String
  loops        Json
  counters     Json
}

/// Small persistent memory the bot writes for itself — currently a single
/// "lessons" row: guidelines distilled daily from operator decisions and
/// posted-reply outcomes, injected into the classifier and reply prompts.
model BotMemory {
  id        String   @id
  content   String
  /// What evidence produced this digest (for auditing the learning loop)
  basis     Json?
  updatedAt DateTime @updatedAt
}

// ── Deal tracker ────────────────────────────────────────────
// Operator-curated watchlist of Amazon listings; when a tracked item's price
// drops to/below its target the bot posts a standalone deal alert to its own
// profile. See docs/adr/0011-deal-tracker.md.

/// Per-listing re-arm state. ARMED = eligible to fire; DISARMED = fired,
/// waiting for the price to rise back above target before it can fire again;
/// FIRED = momentary exactly-once claim between the price trigger and the
/// DealPost row being created (a recovery sweep resets a stranded FIRED).
enum DealArmState {
  ARMED
  DISARMED
  FIRED
}

/// DealPost lifecycle — the exact analog of ReplyStatus. PENDING = fired,
/// awaiting copy generation; PENDING_APPROVAL = feed-discovered deal waiting
/// for the operator (expires when the price snapshot goes stale); READY = has
/// post text, claimable by the deal poster (manual rows start here); POSTING =
/// exactly-once claim; DRY_RUN = would-post record written when DRY_RUN is on
/// (never published).
enum DealPostStatus {
  PENDING
  PENDING_APPROVAL
  READY
  POSTING
  POSTED
  SKIPPED
  FAILED
  DRY_RUN
}

/// How a deal post was triggered. AUTOMATED = watchlist price trigger;
/// DISCOVERED = found on sale by a DealFeed search; MANUAL = operator.
enum DealSource {
  AUTOMATED
  DISCOVERED
  MANUAL
}

/// How a TrackedListing entered the table. WATCHLIST rows are operator-curated
/// and polled by the price checker; DISCOVERED rows are created by deal-feed
/// searches purely as per-ASIN dedup/cooldown state — they are never polled.
enum ListingOrigin {
  WATCHLIST
  DISCOVERED
}

/// One watched Amazon listing plus its persisted detection state.
model TrackedListing {
  id          String @id @default(cuid())
  /// 10-char ASIN extracted from the operator URL.
  asin        String
  /// Marketplace host the ASIN/price belong to (prices are marketplace-specific).
  marketplace String @default("www.amazon.com")
  /// Canonical, tag-FREE product URL. The affiliate tag is applied at
  /// queue/post time via withAffiliateTag, never stored here.
  productUrl  String
  /// Operator-set display title, used verbatim in post copy.
  title       String
  /// Optional Amazon-hosted image (linked live at post time, never re-hosted).
  imageUrl    String?
  /// The item's normal/full price in integer cents (49999 = $499.99). When
  /// set, the % discount in the post is computed against this, and the listing
  /// posts on ANY drop below it (unless a stricter targetPriceCents narrows it).
  fullPriceCents   Int?
  /// Optional stricter alert threshold in cents: only post at/below this. Null
  /// = post on any drop below fullPriceCents. At least one of the two is set.
  targetPriceCents Int?
  /// ISO-4217 currency the prices are denominated in.
  currency    String @default("USD")
  /// Operator on/off switch. Inactive rows are never polled and never posted.
  isActive    Boolean @default(true)
  /// WATCHLIST = operator-curated (polled); DISCOVERED = created by a deal
  /// feed as dedup state (never polled; deactivating one bans the ASIN).
  origin      ListingOrigin @default(WATCHLIST)

  // ── detection state (written by the worker / manual action, not CRUD) ──
  armState             DealArmState @default(ARMED)
  lastPriceCents       Int?
  lastPriceAsOf        DateTime?
  /// Price that fired the last post — identical-price dedup compares to this.
  lastPostedPriceCents Int?
  lastCheckedAt        DateTime?
  lastAvailability     String?
  lastCheckError       String?
  /// When the bot last POSTED a deal (not stamped under DRY_RUN) — feeds the
  /// per-listing cooldown, restart-proof.
  lastPostedAt         DateTime?
  /// Provenance of lastPrice: "PAAPI" | "MANUAL".
  source               String @default("MANUAL")
  /// Consecutive poll failures; auto-deactivates the row at the configured cap.
  consecutiveErrors    Int @default(0)
  /// Backoff gate: the poll query skips this row until now >= nextCheckAt.
  nextCheckAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dealPosts DealPost[]

  @@unique([asin, marketplace])
  @@index([isActive, armState, nextCheckAt])
}

/// One deal alert — the audit + publish-queue ledger (analog of BotReply).
model DealPost {
  id        String         @id @default(cuid())
  listingId String
  listing   TrackedListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  status    DealPostStatus @default(PENDING)
  source    DealSource     @default(AUTOMATED)
  /// Price that fired this post, frozen at fire time (cents).
  salePriceCents   Int
  /// Snapshot of the target at fire time (cents).
  targetPriceCents Int
  /// Reference/"was" price for the savings line, when known (cents).
  wasPriceCents    Int?
  currency         String @default("USD")
  /// "as of" time shown in the post (Amazon price-freshness compliance),
  /// snapshotted so later listing edits can't change what was advertised.
  priceAsOf        DateTime
  /// Tag-enforced affiliate link, snapshotted at queue time.
  linkUrl          String
  /// Frozen post copy; must contain a disclosure token before POSTING.
  postText         String?
  /// The clickable phrase inside postText the link facet rides on. Null =
  /// legacy rows using the classic fixed anchor ("grab it on Amazon").
  linkAnchor       String?
  /// The deal feed that discovered this deal (DISCOVERED source only).
  feedId           String?
  feed             DealFeed? @relation(fields: [feedId], references: [id], onDelete: SetNull)
  /// AT URI once POSTED.
  postUri          String?
  skipReason       String?
  attemptCount     Int @default(0)
  nextAttemptAt    DateTime?
  postedAt         DateTime?

  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([status, createdAt])
  @@index([createdAt])
}

/// Lifecycle of an RSS-sourced deal suggestion. NEW = awaiting the operator;
/// QUEUED = operator confirmed the price and a DealPost was queued; DISMISSED
/// = operator passed; EXPIRED = nobody acted before the deal went stale.
enum SuggestionStatus {
  NEW
  QUEUED
  DISMISSED
  EXPIRED
}

/// One RSS feed of deals (e.g. a Slickdeals feed) the worker polls for
/// Amazon items, plus the topical lane it should keep ("tech & electronics",
/// "pop-culture apparel"). Bridges the no-PA-API gap: suggestions carry a
/// price HINT only — the operator confirms the real price before anything
/// posts, so no third-party price is ever advertised unattested.
model DealSuggestionSource {
  id   String @id @default(cuid())
  /// Display name, unique so seeding stays idempotent.
  name String @unique
  /// RSS 2.0 feed URL.
  url  String
  /// Plain-words criteria for what belongs in this lane — the LLM topical
  /// gate judges each item title against this.
  topic String
  /// Cheap prefilter: when non-empty, an item title must contain at least one
  /// (case-insensitive) before it reaches the LLM gate.
  includeKeywords String[] @default([])
  /// Item titles containing any of these never become suggestions.
  excludeKeywords String[] @default([])
  /// Optional price band applied to the parsed hint price (when present).
  minPriceCents Int?
  maxPriceCents Int?
  isActive Boolean @default(true)

  // ── run state (written by the worker) ──
  lastFetchedAt   DateTime?
  lastItemCount   Int @default(0)
  lastQueuedCount Int @default(0)
  lastFetchError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  suggestions DealSuggestion[]

  @@index([isActive, lastFetchedAt])
}

/// One Amazon item found in a deal RSS feed, waiting for the operator to
/// confirm the price and queue a post (or dismiss it). Never posts by itself.
model DealSuggestion {
  id       String               @id @default(cuid())
  sourceId String
  source   DealSuggestionSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  /// RSS item guid (or link fallback) — the per-source dedup key.
  guid  String
  /// Raw RSS item title (deal headline, often includes the price).
  title String
  asin        String
  marketplace String @default("www.amazon.com")
  /// Canonical, tag-FREE product URL rebuilt from the ASIN — the source's
  /// affiliate/redirect params never survive.
  productUrl String
  /// Price parsed from the deal headline, integer cents — a HINT the operator
  /// must confirm; never advertised as-is.
  hintPriceCents Int?
  /// The deal thread/page for the operator to double-check.
  sourceUrl String?
  status    SuggestionStatus @default(NEW)
  /// Topical-gate audit: verdict + confidence + model (or "keywords-only").
  gateVerdict Json?

  createdAt DateTime @default(now())

  @@unique([sourceId, guid])
  @@index([status, createdAt])
  @@index([asin])
}

/// One saved PA-API SearchItems query the discovery loop runs on a schedule:
/// "find products in this category, currently discounted at least X%". The
/// Wario64-style feed control panel — each row is an independent deal search.
model DealFeed {
  id       String @id @default(cuid())
  /// Display name, unique so seeding stays idempotent ("Video game deals").
  name     String @unique
  /// PA-API SearchItems Keywords (free-text product search).
  keywords String
  /// PA-API SearchIndex (category) the search runs in, e.g. "VideoGames".
  searchIndex String @default("All")
  /// Only queue items discounted at least this % off Amazon's own list price
  /// (SavingBasis). Server-side re-checked — never trusted from the API filter.
  minSavingPercent Int @default(20)
  /// Optional price band in cents — skip trinkets and grails.
  minPriceCents Int?
  maxPriceCents Int?
  /// Quality floors, applied only when PA-API returns review data (0 = off).
  minReviewCount  Int @default(50)
  /// 1–4: PA-API MinReviewsRating (items rated above this many stars).
  minReviewRating Int @default(4)
  /// true = only offers sold by Amazon itself (Merchant=Amazon). Third-party
  /// strikethrough prices are often inflated; Amazon's own are trustworthy.
  amazonOnly Boolean @default(true)
  isActive   Boolean @default(true)

  // ── run state (written by the worker) ──
  lastRunAt       DateTime?
  lastFoundCount  Int @default(0)
  lastQueuedCount Int @default(0)
  lastRunError    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dealPosts DealPost[]

  @@index([isActive, lastRunAt])
}
