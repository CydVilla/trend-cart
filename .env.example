# ── Database ────────────────────────────────────────────────
# Matches docker-compose.yml. On Heroku, use the DATABASE_URL from Heroku Postgres.
DATABASE_URL=postgresql://trendcart:trendcart@localhost:5433/trendcart

# ── Bluesky bot account ─────────────────────────────────────
# Create an app password at Settings → Privacy & Security → App Passwords.
# NEVER use your real account password here.
BOT_ACCOUNT_HANDLE=trend-cart.bsky.social
BOT_APP_PASSWORD=


# ── LLM (classification + reply generation) ─────────────────
ANTHROPIC_API_KEY=
# Haiku keeps classification ~10x cheaper than Opus; switch to
# claude-opus-4-8 if you want maximum judgment and cost is no concern.
ANTHROPIC_MODEL=claude-haiku-4-5
# true = deterministic fake LLM (no API calls) for testing the pipeline
USE_FAKE_LLM=false
# Hard cap on LLM evaluations per hour (cost control). Keep this generous:
# the July insights run showed 81% of reply skips were candidates EXPIRING
# in the eval backlog — a too-low cap costs replies, not just latency.
MAX_LLM_EVALS_PER_HOUR=50

# ── Click tracking ──────────────────────────────────────────
# Route posted affiliate links through a first-party /r/<id> redirect that
# counts clicks (per-post revenue signal Amazon never provides). The redirect
# is guaranteed, the count best-effort — failures still bounce to Amazon.
# OFF by default: enabling puts the (sleep-prone Eco) web dyno in front of
# every link. Needs PUBLIC_BASE_URL, the deployed web app's origin.
CLICK_TRACKING_ENABLED=false
# PUBLIC_BASE_URL=https://your-app.herokuapp.com

# ── Amazon affiliate ────────────────────────────────────────
# Your Amazon Associates store ID (tag=... query param on product/search URLs).
AMAZON_ASSOCIATE_TAG=villa03b-20

# ── Ingestion (Phase 3) ─────────────────────────────────────
# How often to poll Bluesky search for trending candidates (minutes)
DISCOVER_INTERVAL_MINUTES=15
# Skip posts shorter than this many characters
MIN_POST_LENGTH=40
# Only ingest posts whose langs include "en"
REQUIRE_ENGLISH=true
# Refresh engagement counts for stored posts this often (minutes)
REHYDRATE_INTERVAL_MINUTES=15
# Stop refreshing posts older than this (hours) — stale posts aren't trends
REHYDRATE_MAX_AGE_HOURS=24
# Never ingest a post older than this (hours): candidates expire 24h after
# the post, so ones discovered near that wall burn an eval and die queued —
# and a reply that late lands on a dead thread anyway.
MAX_CANDIDATE_AGE_HOURS=16

# ── Multimodal context (classification + reply) ─────────────
# Send post image THUMBNAILS to the model as vision input (sees screenshots,
# box art, physical editions instead of guessing from hashtags). Thumbnails
# keep this ~$0.10–0.15/day at the eval cap.
VISION_ENABLED=true
VISION_MAX_IMAGES=2
# Pull the post's top replies (public API, free) as conversation context.
COMMENTS_ENABLED=true
COMMENTS_MAX=5
COMMENTS_MIN_LENGTH=15

# ── Bot behavior & safety ───────────────────────────────────
# DRY_RUN=true means the bot never posts, only records what it WOULD post.
DRY_RUN=true
# dry_run | manual | auto  (manual = replies queue for approval in the dashboard)
REPLY_MODE=manual
# Replies are the SECONDARY channel (the profile's deal posts do the volume):
# caps apply to UNSOLICITED trending replies only — mentions and operator
# injections bypass them, and the daily banter reply has its own budget.
MAX_REPLIES_PER_HOUR=1
MAX_REPLIES_PER_DAY=3
# Replies are validated against this before storing/posting (Bluesky max is 300)
REPLY_MAX_LENGTH=240
# 85: a trending reply must be rare and excellent. The operator's 👎 ratings
# clustered on marginal candidates (non-existent / sold-out / over-general
# products) — don't lower this without re-checking calibration numbers.
MIN_PRODUCT_INTENT_SCORE=85
# Don't reply to the same author more than once per window (hours)
AUTHOR_COOLDOWN_HOURS=72
# Don't recommend the same category twice within this window (minutes)
CATEGORY_COOLDOWN_MINUTES=60
# Minimum gap between unsolicited trending replies (minutes)
GLOBAL_REPLY_COOLDOWN_MINUTES=90
# Trending floor: firehose posts need this engagement score (likes*1 +
# reposts*3 + replies*2 + quotes*3) after maturing before the LLM sees them.
# Mentions and manual injections are exempt. Raise for stricter "trending".
# Per-category overrides live in the dashboard (Categories → Min engagement
# floor) — lower a high-conviction category without loosening everything.
MIN_ENGAGEMENT_SCORE=10

# Link quality: a recommended Amazon search query below this confidence (0-100)
# is never linked and the reply is SKIPPED — there is no generic fallback;
# every reply names a specific product (retro games link the modern remaster).
MIN_LINK_CONFIDENCE=75

# Autonomous mode (dashboard toggle) self-approves replies only above BOTH
# bars; weaker replies still queue for manual approval. DRY_RUN overrides.
AUTO_MIN_INTENT_SCORE=90
AUTO_MIN_LINK_CONFIDENCE=85
# PLAYFUL (joke-first) replies always queue for manual approval until you
# trust the bot's humor — flip on to let them self-post like everything else.
PLAYFUL_AUTO_APPROVE=false

# ── Trending banter (daily humor reply — the organic-growth surface) ──
# Once a day: find a popular post under Bluesky's trending topics (politics/
# news/tragedy filtered out), read its top-liked replies to sense the room,
# and reply with the bot's OWN funny take — no link, no ad, no product. The
# humor judge must clear BANTER_MIN_CONFIDENCE or the day is skipped
# ("silence beats cringe"). Rides the normal reply rails (ratings, 👎
# takedown, opt-outs); its budget is separate from the reply caps.
BANTER_ENABLED=true
# BANTER_PER_DAY=1
# BANTER_MAX_CANDIDATES=3
# BANTER_MIN_LIKES=50
# BANTER_MIN_CONFIDENCE=70
# BANTER_MAX_LENGTH=240

# ── Pre-publication fact check (unreviewed auto-posts) ──────
# A reply about to post with NO human review gets one LLM call with the
# server-side web_search tool: does the product exist and is it orderable,
# are the claims right? Fail-safe — failures demote to the manual queue.
FACTCHECK_ENABLED=true
# FACTCHECK_MAX_SEARCHES=3
# FACTCHECK_MIN_CONFIDENCE=60

# ── One-shot apologies (negative replies to the bot) ────────
# A reply that's negative TOWARD THE BOT earns one fixed-template apology
# (the LLM only gates WHETHER — a stranger's words never shape the text).
# Opt-outs get silence instead. 👎-rating a posted reply also deletes it
# from Bluesky within ~2 min (the record stays for learning).
APOLOGY_ENABLED=true
# APOLOGY_MIN_CONFIDENCE=70
# APOLOGY_MAX_PER_DAY=3
# APOLOGY_AUTHOR_COOLDOWN_DAYS=7

# ── Operator email pings (Resend) ───────────────────────────
# Email when actionable items wait in the approval queues (pending replies,
# deal posts). At most one per NOTIFY_MIN_INTERVAL_HOURS, and
# only when something is NEW since the last ping. Ships dark until both
# RESEND_API_KEY and NOTIFY_EMAIL_TO are set. NOTE: the default from-address
# (onboarding@resend.dev) only delivers to your own Resend account email.
# RESEND_API_KEY=
# NOTIFY_EMAIL_TO=you@example.com
# NOTIFY_EMAIL_FROM=TrendCart <onboarding@resend.dev>
# NOTIFY_MIN_INTERVAL_HOURS=4
# DASHBOARD_URL=https://your-app.herokuapp.com/

# ── Deal channel (automated deal-alert posts to the bot's own profile) ──
# Ships dark. Set true to run the deal loops on the worker. Two automated
# paths feed one exactly-once poster: the RSS channel (below, live today,
# no Amazon keys) and PA-API feed discovery (attested prices, once keys
# exist).
DEALS_ENABLED=false
# Amazon Product Advertising API 5.0 — unlocks AUTOMATED price polling.
# Requires an approved Associate account with 3+ qualifying sales in 180 days.
# Leave empty until then — the RSS channel below needs no keys.
PA_API_ACCESS_KEY=
PA_API_SECRET_KEY=
PA_API_PARTNER_TAG=
PA_API_MARKETPLACE=www.amazon.com
# Anti-spam / behavior (defaults shown; uncomment to override):
# DEAL_MAX_POSTS_PER_DAY=3
# DEAL_PER_LISTING_COOLDOWN_HOURS=168
# DEAL_GLOBAL_COOLDOWN_MINUTES=60
# DEAL_MAX_PRICE_AGE_HOURS=1

# Post copy style: "wario" (default) = terse deal-account format, the price
# phrase is the clickable link ("Title is $39.99 on Amazon (33% off) #ad");
# "classic" = the original lead-in format on the fixed anchor.
# DEAL_POST_STYLE=wario

# ── Deal feeds (Wario64-style sale discovery; needs PA-API keys) ──
# The worker polls each active DealFeed (Deals page) via PA-API SearchItems
# for products currently on sale — real strikethrough discounts only, every
# gate re-checked server-side. Discovered deals queue for approval on the
# Deals page and expire when the price snapshot goes stale…
# DEAL_FEED_AUTOPOST=false
# DEAL_DISCOVERY_INTERVAL_MINUTES=30
# DEAL_DISCOVERY_FEEDS_PER_TICK=4
# DEAL_DISCOVERY_PAGES_PER_FEED=1
# Daily budget for PA-API feed finds — kept under DEAL_MAX_POSTS_PER_DAY so
# they share the day fairly with the RSS channel.
# DEAL_FEED_MAX_POSTS_PER_DAY=2
#
# …for a real Wario64-cadence feed once you trust it, flip autopost on and
# raise the caps, e.g.:
# DEAL_FEED_AUTOPOST=true
# DEAL_MAX_POSTS_PER_DAY=12
# DEAL_FEED_MAX_POSTS_PER_DAY=10
# DEAL_GLOBAL_COOLDOWN_MINUTES=20

# ── RSS deal channel (fully automated, NO PA-API keys) ──
# Polls deal-site RSS feeds (Deals page → Deal RSS sources; Slickdeals
# seeded) for Amazon items in each source's topical lane, corroborates each
# survivor with a web-search fact check (fail-closed), and SELF-POSTS with
# PRICE-FREE, source-attributed copy ("spotted on Slickdeals") — no
# third-party price is ever advertised, which is what keeps automation
# compliant without PA-API. Needs DEALS_ENABLED=true + an LLM key.
# DEAL_RSS_AUTOPOST=false is audit-only: rows recorded, nothing publishes.
DEAL_RSS_AUTOPOST=false
# DEAL_RSS_MAX_POSTS_PER_DAY=2
# DEAL_SUGGESTIONS_ENABLED=true
# DEAL_SUGGEST_INTERVAL_MINUTES=30
# DEAL_SUGGEST_SOURCES_PER_TICK=2
# DEAL_SUGGEST_MAX_ITEMS_PER_FETCH=30
# DEAL_SUGGEST_EXPIRE_HOURS=48
# DEAL_SUGGEST_MIN_TOPIC_CONFIDENCE=70
# DEAL_SUGGEST_MAX_LLM_PER_TICK=20

# Low-signal gate: statement posts (no question/ask) need floor × this
# multiplier engagement before LLM evaluation. Enthusiast posts are usually
# statements — keep modest.
LOW_SIGNAL_MULTIPLIER=2
